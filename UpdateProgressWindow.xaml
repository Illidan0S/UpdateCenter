<Window x:Class="UpdateCenter.UpdateProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Installazione aggiornamenti" Width="620" Height="430"
        WindowStartupLocation="CenterOwner" WindowStyle="None" AllowsTransparency="True"
        ResizeMode="NoResize" Background="Transparent" ShowInTaskbar="False">
    <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1" CornerRadius="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="54" />
                <RowDefinition Height="*" />
                <RowDefinition Height="76" />
            </Grid.RowDefinitions>

            <Grid Margin="22,0,12,0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <TextBlock x:Name="WindowTitleText" Text="Installazione aggiornamenti"
                           FontSize="{DynamicResource FontSize16}" FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="—" Style="{StaticResource SecondaryButton}" ToolTip="Riduci a icona"
                            Width="36" Height="34" Padding="0" Click="Minimize_Click" />
                    <Button x:Name="HeaderCloseButton" Content="×" Style="{StaticResource SecondaryButton}"
                            ToolTip="Nascondi avanzamento" Width="36" Height="34" Padding="0" Margin="8,0,0,0"
                            Click="Close_Click" />
                </StackPanel>
            </Grid>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="28,12,28,18">
                <StackPanel>
                    <Border Width="58" Height="58" CornerRadius="18" HorizontalAlignment="Left"
                            Background="{DynamicResource AccentSoftBrush}" BorderBrush="{DynamicResource AccentSoftBorderBrush}"
                            BorderThickness="1" Margin="0,0,0,16">
                        <TextBlock x:Name="StateIconText" Text="↻" Foreground="{DynamicResource AccentBrush}"
                                   FontSize="{DynamicResource FontSize27}" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>

                    <TextBlock x:Name="StateTitleText" Text="Aggiornamento in corso"
                               FontSize="{DynamicResource FontSize23}" FontWeight="SemiBold" TextWrapping="Wrap" />
                    <TextBlock x:Name="StateDetailText" Text="{Binding CurrentItemText}"
                               Foreground="{DynamicResource MutedTextBrush}" Margin="0,6,0,22"
                               TextWrapping="Wrap" MinHeight="38" />

                    <Border Background="{DynamicResource SurfaceAltBrush}" CornerRadius="14" Padding="18">
                        <StackPanel>
                            <Grid>
                                <TextBlock Text="Avanzamento installazione" FontWeight="SemiBold" />
                                <TextBlock x:Name="PercentageText" Text="{Binding Progress, StringFormat={}{0:0}%}"
                                           HorizontalAlignment="Right" Foreground="{DynamicResource AccentBrush}"
                                           FontWeight="SemiBold" />
                            </Grid>
                            <ProgressBar x:Name="InstallationProgressBar" Value="{Binding Progress, Mode=OneWay}"
                                         Maximum="100" Height="10" Margin="0,13,0,10" />
                            <TextBlock x:Name="OperationStatusText" Text="{Binding StatusText}"
                                       Foreground="{DynamicResource MutedTextBrush}" FontSize="{DynamicResource FontSize11}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <UniformGrid x:Name="ResultCards" Columns="2" Margin="0,16,0,0" Visibility="Collapsed">
                        <Border Background="{DynamicResource AccentSoftBrush}" CornerRadius="12" Padding="14" Margin="0,0,6,0">
                            <StackPanel>
                                <TextBlock Text="RIUSCITI" Foreground="{DynamicResource MutedTextBrush}"
                                           FontSize="{DynamicResource FontSize10}" />
                                <TextBlock x:Name="SucceededCountText" Foreground="{DynamicResource SuccessBrush}"
                                           FontSize="{DynamicResource FontSize23}" FontWeight="SemiBold" Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>
                        <Border Background="{DynamicResource DangerSoftBrush}" CornerRadius="12" Padding="14" Margin="6,0,0,0">
                            <StackPanel>
                                <TextBlock Text="NON RIUSCITI" Foreground="{DynamicResource MutedTextBrush}"
                                           FontSize="{DynamicResource FontSize10}" />
                                <TextBlock x:Name="FailedCountText" Foreground="{DynamicResource DangerBrush}"
                                           FontSize="{DynamicResource FontSize23}" FontWeight="SemiBold" Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <Border x:Name="CompletionNotice" Visibility="Collapsed" Margin="0,14,0,0"
                            Background="{DynamicResource WarningSoftBrush}" CornerRadius="12" Padding="14">
                        <TextBlock x:Name="CompletionNoticeText" Foreground="{DynamicResource WarningBrush}"
                                   TextWrapping="Wrap" />
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2" Background="{DynamicResource SurfaceAltBrush}" CornerRadius="0,0,20,20"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
                <Grid Margin="24,14">
                    <TextBlock x:Name="FooterText" Text="L'operazione può richiedere alcuni minuti."
                               Foreground="{DynamicResource MutedTextBrush}" FontSize="{DynamicResource FontSize11}"
                               VerticalAlignment="Center" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="CloseButton" Content="Chiudi" Style="{StaticResource SecondaryButton}"
                                Visibility="Collapsed" Click="Close_Click" />
                        <Button x:Name="RestartButton" Content="Riavvia ora" Style="{StaticResource RoundedButton}"
                                Margin="10,0,0,0" Visibility="Collapsed" Click="Restart_Click" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
