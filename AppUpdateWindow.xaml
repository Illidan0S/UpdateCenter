<Window x:Class="UpdateCenter.AppUpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Aggiornamento Update Center" Width="700" Height="620"
        WindowStartupLocation="CenterOwner" WindowStyle="None" AllowsTransparency="True"
        ResizeMode="NoResize" Background="Transparent" ShowInTaskbar="False">
    <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1" CornerRadius="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="54" />
                <RowDefinition Height="*" />
                <RowDefinition Height="82" />
            </Grid.RowDefinitions>

            <Grid Margin="22,0,12,0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <TextBlock Text="Aggiornamento di Update Center" FontSize="{DynamicResource FontSize16}"
                           FontWeight="SemiBold" VerticalAlignment="Center" />
                <Button x:Name="CloseButton" Content="×" Style="{StaticResource SecondaryButton}"
                        Width="36" Height="34" Padding="0" HorizontalAlignment="Right"
                        VerticalAlignment="Center" Click="Later_Click" />
            </Grid>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="26,10,26,18">
                <StackPanel>
                    <TextBlock Text="È disponibile una nuova versione" FontSize="{DynamicResource FontSize24}"
                               FontWeight="SemiBold" TextWrapping="Wrap" />
                    <TextBlock Text="Il download proviene dalla Release stabile ufficiale e verrà verificato con SHA-256."
                               Foreground="{DynamicResource MutedTextBrush}" Margin="0,7,0,20" TextWrapping="Wrap" />

                    <UniformGrid Columns="3" Margin="0,0,0,18">
                        <Border Background="{DynamicResource SurfaceAltBrush}" CornerRadius="12" Padding="14" Margin="0,0,6,0">
                            <StackPanel>
                                <TextBlock Text="INSTALLATA" Foreground="{DynamicResource MutedTextBrush}" FontSize="{DynamicResource FontSize10}" />
                                <TextBlock Text="{Binding InstalledVersionLabel}" FontSize="{DynamicResource FontSize18}"
                                           FontWeight="SemiBold" Margin="0,5,0,0" />
                            </StackPanel>
                        </Border>
                        <Border Background="{DynamicResource AccentSoftBrush}" BorderBrush="{DynamicResource AccentSoftBorderBrush}"
                                BorderThickness="1" CornerRadius="12" Padding="14" Margin="3,0">
                            <StackPanel>
                                <TextBlock Text="NUOVA" Foreground="{DynamicResource AccentBrush}" FontSize="{DynamicResource FontSize10}" />
                                <TextBlock Text="{Binding AvailableVersionLabel}" Foreground="{DynamicResource AccentBrush}"
                                           FontSize="{DynamicResource FontSize18}" FontWeight="SemiBold" Margin="0,5,0,0" />
                            </StackPanel>
                        </Border>
                        <Border Background="{DynamicResource SurfaceAltBrush}" CornerRadius="12" Padding="14" Margin="6,0,0,0">
                            <StackPanel>
                                <TextBlock Text="DOWNLOAD" Foreground="{DynamicResource MutedTextBrush}" FontSize="{DynamicResource FontSize10}" />
                                <TextBlock Text="{Binding DownloadSizeLabel}" FontSize="{DynamicResource FontSize18}"
                                           FontWeight="SemiBold" Margin="0,5,0,0" />
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <TextBlock Text="Note della Release" FontSize="{DynamicResource FontSize15}" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <TextBox Text="{Binding ReleaseNotes, Mode=OneWay}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap"
                             MinHeight="150" MaxHeight="230" VerticalScrollBarVisibility="Auto"
                             VerticalContentAlignment="Top" SelectionBrush="{DynamicResource SelectionBrush}" />

                    <StackPanel x:Name="ProgressPanel" Visibility="Collapsed" Margin="0,18,0,0">
                        <ProgressBar x:Name="DownloadProgress" Minimum="0" Maximum="100" />
                        <TextBlock x:Name="DownloadStatus" Foreground="{DynamicResource MutedTextBrush}"
                                   Margin="0,8,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2" Background="{DynamicResource SurfaceAltBrush}" CornerRadius="0,0,20,20"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
                <Grid Margin="24,16">
                    <TextBlock Text="Non sono richiesti privilegi amministrativi nell'installazione per utente."
                               Foreground="{DynamicResource MutedTextBrush}" FontSize="{DynamicResource FontSize10}"
                               VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="270" HorizontalAlignment="Left" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="IgnoreButton" Content="Ignora questa versione" Style="{StaticResource SecondaryButton}"
                                Padding="13,9" Click="Ignore_Click" />
                        <Button x:Name="LaterButton" Content="Più tardi" Style="{StaticResource SecondaryButton}"
                                Margin="8,0,0,0" Padding="13,9" Click="Later_Click" />
                        <Button x:Name="UpdateButton" Content="Aggiorna ora" Style="{StaticResource RoundedButton}"
                                Margin="8,0,0,0" Padding="15,9" Click="Update_Click" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
