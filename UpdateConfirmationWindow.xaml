<Window x:Class="UpdateCenter.UpdateConfirmationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Conferma aggiornamenti" Width="760" Height="650"
        WindowStartupLocation="CenterOwner" WindowStyle="None" AllowsTransparency="True"
        ResizeMode="NoResize" Background="Transparent" ShowInTaskbar="False">
    <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1" CornerRadius="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="54" />
                <RowDefinition Height="*" />
                <RowDefinition Height="76" />
            </Grid.RowDefinitions>

            <Grid Margin="22,0,12,0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <TextBlock Text="Riepilogo prima dell'installazione" FontSize="{DynamicResource FontSize16}" FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                <Button Content="×" Style="{StaticResource SecondaryButton}" Width="36" Height="34" Padding="0"
                        HorizontalAlignment="Right" VerticalAlignment="Center" Click="Cancel_Click" />
            </Grid>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,8,24,12">
                <StackPanel>
                    <TextBlock x:Name="SummaryText" FontSize="{DynamicResource FontSize23}" FontWeight="SemiBold" TextWrapping="Wrap" />
                    <TextBlock Text="Controlla gli elementi: l'installazione inizierà solo dopo la tua conferma."
                               Foreground="{DynamicResource MutedTextBrush}" Margin="0,6,0,18" />

                    <UniformGrid Columns="3" Margin="0,0,0,16">
                        <Border Background="{DynamicResource SurfaceAltBrush}" CornerRadius="12" Padding="14" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="IMPORTANTI" Foreground="{DynamicResource MutedTextBrush}" FontSize="{DynamicResource FontSize10}" />
                                <TextBlock x:Name="ImportantCountText" FontSize="{DynamicResource FontSize23}" FontWeight="SemiBold" Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>
                        <Border Background="{DynamicResource SurfaceAltBrush}" CornerRadius="12" Padding="14" Margin="4,0">
                            <StackPanel>
                                <TextBlock Text="SOFTWARE" Foreground="{DynamicResource MutedTextBrush}" FontSize="{DynamicResource FontSize10}" />
                                <TextBlock x:Name="SoftwareCountText" FontSize="{DynamicResource FontSize23}" FontWeight="SemiBold" Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>
                        <Border Background="{DynamicResource SurfaceAltBrush}" CornerRadius="12" Padding="14" Margin="8,0,0,0">
                            <StackPanel>
                                <TextBlock Text="DRIVER" Foreground="{DynamicResource MutedTextBrush}" FontSize="{DynamicResource FontSize10}" />
                                <TextBlock x:Name="DriverCountText" FontSize="{DynamicResource FontSize23}" FontWeight="SemiBold" Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <UniformGrid Columns="2" Margin="0,0,0,14">
                        <Border Background="{DynamicResource SurfaceAltBrush}" CornerRadius="12" Padding="14" Margin="0,0,6,0">
                            <StackPanel>
                                <TextBlock Text="ALIMENTAZIONE" Foreground="{DynamicResource MutedTextBrush}" FontSize="{DynamicResource FontSize10}" />
                                <TextBlock x:Name="PowerStatusText" FontWeight="SemiBold" Margin="0,5,0,0"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                        <Border Background="{DynamicResource SurfaceAltBrush}" CornerRadius="12" Padding="14" Margin="6,0,0,0">
                            <StackPanel>
                                <TextBlock Text="SPAZIO SU DISCO" Foreground="{DynamicResource MutedTextBrush}" FontSize="{DynamicResource FontSize10}" />
                                <TextBlock x:Name="DiskStatusText" FontWeight="SemiBold" Margin="0,5,0,0"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <Border Background="{DynamicResource AccentSoftBrush}" BorderBrush="{DynamicResource AccentSoftBorderBrush}" BorderThickness="1" CornerRadius="12"
                            Padding="14" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="Protezione del sistema" FontWeight="SemiBold" />
                            <TextBlock x:Name="RestorePointText" Foreground="{DynamicResource MutedTextBrush}"
                                       FontSize="{DynamicResource FontSize11}" Margin="0,4,0,0" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <StackPanel x:Name="BlockingPanel" Visibility="Collapsed" Margin="0,0,0,14">
                        <TextBlock Text="Prima di continuare risolvi questi problemi" Foreground="{DynamicResource DangerBrush}"
                                   FontWeight="SemiBold" Margin="0,0,0,6" />
                        <ItemsControl x:Name="BlockingList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="•  " Foreground="{DynamicResource DangerBrush}" />
                                        <TextBlock Grid.Column="1" Text="{Binding}" TextWrapping="Wrap" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <StackPanel x:Name="WarningsPanel" Visibility="Collapsed" Margin="0,0,0,14">
                        <TextBlock Text="Avvisi prima di continuare" Foreground="{DynamicResource WarningBrush}"
                                   FontWeight="SemiBold" Margin="0,0,0,6" />
                        <ItemsControl x:Name="WarningsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,2">
                                        <TextBlock Text="•  " />
                                        <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="12"
                            ClipToBounds="True">
                        <DataGrid x:Name="ItemsGrid" IsReadOnly="True" MaxHeight="230" RowHeight="46">
                            <DataGrid.Resources>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource DataGridText}" />
                            </DataGrid.Resources>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Nome" Binding="{Binding Name}" Width="2*"
                                                    ElementStyle="{StaticResource DataGridText}" />
                                <DataGridTextColumn Header="Tipo" Binding="{Binding KindLabel}" Width="80"
                                                    ElementStyle="{StaticResource DataGridText}" />
                                <DataGridTextColumn Header="Priorità" Binding="{Binding PriorityLabel}" Width="105"
                                                    ElementStyle="{StaticResource DataGridText}" />
                                <DataGridTextColumn Header="Nuova versione" Binding="{Binding AvailableVersion}" Width="130"
                                                    ElementStyle="{StaticResource DataGridText}" />
                                <DataGridTextColumn Header="Riavvio" Binding="{Binding RestartLabel}" Width="75"
                                                    ElementStyle="{StaticResource DataGridText}" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2" Background="{DynamicResource SurfaceAltBrush}" CornerRadius="0,0,20,20"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
                <Grid Margin="24,14">
                    <TextBlock x:Name="FooterInfoText" Text="Verrà mostrata la richiesta amministratore di Windows."
                               Foreground="{DynamicResource MutedTextBrush}" FontSize="{DynamicResource FontSize11}" VerticalAlignment="Center" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Annulla" Style="{StaticResource SecondaryButton}" Click="Cancel_Click" />
                        <Button x:Name="ConfirmButton" Content="Conferma e aggiorna" Style="{StaticResource RoundedButton}" Margin="10,0,0,0"
                                Click="Confirm_Click" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
