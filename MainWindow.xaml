<Window x:Class="UpdateCenter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Update Center" Icon="Assets/UpdateCenter.ico" Width="1240" Height="790" MinWidth="720" MinHeight="500"
        WindowStartupLocation="CenterScreen" WindowStyle="None" AllowsTransparency="True"
        ResizeMode="CanResize" Background="Transparent" UseLayoutRounding="True" SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display">
    <Window.Resources>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="22" />
        </Style>
        <Style x:Key="WindowButton" TargetType="Button">
            <Setter Property="Width" Value="42" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="{DynamicResource FontSize15}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="B" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="B" Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="WindowBorder" CornerRadius="22" Background="{DynamicResource BackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="TitleSidebarColumn" Width="230" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel x:Name="BrandPanel" Orientation="Horizontal" Margin="20,0,0,0" VerticalAlignment="Center">
                    <Image Source="Assets/UpdateCenter.ico" Width="28" Height="28" Stretch="Uniform" />
                    <TextBlock x:Name="AppNameText" Text="Update Center" Margin="10,0,0,0" VerticalAlignment="Center"
                               FontWeight="SemiBold" FontSize="{DynamicResource FontSize14}" />
                    <Border x:Name="VersionBadge" Margin="8,0,0,0" Padding="7,3" VerticalAlignment="Center"
                            Background="{DynamicResource AccentSoftBrush}" BorderBrush="{DynamicResource AccentSoftBorderBrush}"
                            BorderThickness="1" CornerRadius="7">
                        <TextBlock x:Name="VersionText" Text="v1.0.3" Foreground="{DynamicResource AccentBrush}"
                                   FontSize="{DynamicResource FontSize10}" FontWeight="SemiBold" />
                    </Border>
                </StackPanel>
                <TextBlock Grid.Column="1" x:Name="PageTitle" Text="Home" Foreground="{DynamicResource MutedTextBrush}"
                           VerticalAlignment="Center" Margin="24,0" />
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,7,10,7">
                    <Button Style="{StaticResource WindowButton}" Content="—" Click="Minimize_Click" />
                    <Button Style="{StaticResource WindowButton}" Content="□" Click="Maximize_Click" />
                    <Button Style="{StaticResource WindowButton}" Content="×" Click="Close_Click" />
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="SidebarColumn" Width="230" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Margin="12,0,0,12" CornerRadius="18" Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <Grid Margin="14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock x:Name="SidebarHeading" Text="CONTROLLO PC" Foreground="{DynamicResource MutedTextBrush}" FontSize="{DynamicResource FontSize11}"
                                   FontWeight="SemiBold" Margin="12,10,0,12" />
                        <StackPanel Grid.Row="1">
                            <Button x:Name="HomeNav" Style="{StaticResource NavButton}" Content="⌂   Home" ToolTip="Home" Click="HomeNav_Click" />
                            <Button x:Name="UpdatesNav" Style="{StaticResource NavButton}" Content="↓   Aggiornamenti" ToolTip="Aggiornamenti" Click="UpdatesNav_Click" />
                            <Button x:Name="SystemInfoNav" Style="{StaticResource NavButton}" Content="▤   Hardware" ToolTip="Hardware" Click="SystemInfoNav_Click" />
                            <Button x:Name="HardwareNav" Style="{StaticResource NavButton}" Content="▣   Driver e chipset" ToolTip="Driver e chipset" Click="HardwareNav_Click" />
                            <Button x:Name="HistoryNav" Style="{StaticResource NavButton}" Content="◷   Cronologia" ToolTip="Cronologia" Click="HistoryNav_Click" />
                            <Button x:Name="SettingsNav" Style="{StaticResource NavButton}" Content="⚙   Impostazioni" ToolTip="Impostazioni" Click="SettingsNav_Click" />
                        </StackPanel>
                        <Border x:Name="SidebarSourceCard" Grid.Row="2" Background="{DynamicResource SurfaceAltBrush}" CornerRadius="14" Padding="14" Margin="0,10,0,0">
                            <StackPanel>
                                <TextBlock Text="Controllo locale" FontWeight="SemiBold" FontSize="{DynamicResource FontSize12}" />
                                <TextBlock Text="Nessuna telemetria" Foreground="{DynamicResource MutedTextBrush}"
                                           FontSize="{DynamicResource FontSize11}" Margin="0,4,0,0" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Grid x:Name="ContentHost" Grid.Column="1" Margin="18,0,18,18">
                    <!-- HOME -->
                    <ScrollViewer x:Name="HomePage" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Border Style="{StaticResource Card}" Padding="32" Margin="0,0,0,16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition x:Name="HomeStatusColumn" Width="300" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel x:Name="HomeHeroContent">
                                        <TextBlock Text="Mantieni il PC aggiornato" FontSize="{DynamicResource FontSize30}" FontWeight="SemiBold" />
                                        <TextBlock Text="Controlla software e driver da fonti ufficiali, poi scegli tu cosa installare."
                                                   Foreground="{DynamicResource MutedTextBrush}" FontSize="{DynamicResource FontSize15}" Margin="0,10,20,24"
                                                   TextWrapping="Wrap" />
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="Avvia scansione" Style="{StaticResource RoundedButton}"
                                                    IsEnabled="{Binding CanScan}" Click="Scan_Click" />
                                            <Button Content="Annulla" Style="{StaticResource SecondaryButton}" Margin="10,0,0,0"
                                                    Click="CancelScan_Click" />
                                        </StackPanel>
                                    </StackPanel>
                                    <Border x:Name="HomeStatusCard" Grid.Column="1" Background="{DynamicResource AccentSoftBrush}" CornerRadius="18" Padding="24">
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="STATO" Foreground="{DynamicResource MutedTextBrush}" FontSize="{DynamicResource FontSize11}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding StatusText}" FontSize="{DynamicResource FontSize20}" FontWeight="SemiBold" Margin="0,8,0,4"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                                <StackPanel>
                                    <Grid>
                                        <TextBlock Text="Avanzamento" FontSize="{DynamicResource FontSize15}" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding Progress, StringFormat={}{0:0}%}" HorizontalAlignment="Right"
                                                   Foreground="{DynamicResource MutedTextBrush}" />
                                    </Grid>
                                    <ProgressBar Value="{Binding Progress, Mode=OneWay}" Maximum="100" Margin="0,14,0,10" />
                                    <TextBlock Text="{Binding CurrentItemText}" Foreground="{DynamicResource MutedTextBrush}"
                                               FontSize="{DynamicResource FontSize12}" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Border>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="Elementi trovati" Foreground="{DynamicResource MutedTextBrush}" />
                                        <TextBlock Text="{Binding ScannedCount}" FontSize="{DynamicResource FontSize30}" FontWeight="SemiBold" Margin="0,8,0,0" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="2" Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="Aggiornamenti" Foreground="{DynamicResource MutedTextBrush}" />
                                        <TextBlock Text="{Binding AvailableCount}" FontSize="{DynamicResource FontSize30}" FontWeight="SemiBold" Margin="0,8,0,0" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="4" Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="Selezionati" Foreground="{DynamicResource MutedTextBrush}" />
                                        <TextBlock Text="{Binding SelectedCount}" FontSize="{DynamicResource FontSize30}" FontWeight="SemiBold" Margin="0,8,0,0" />
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Border Style="{StaticResource Card}" Margin="0,16,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="ULTIMA SCANSIONE" Foreground="{DynamicResource MutedTextBrush}"
                                                   FontSize="{DynamicResource FontSize11}" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding LastScanLabel}" FontSize="{DynamicResource FontSize18}" FontWeight="SemiBold" Margin="0,7,0,4" />
                                        <TextBlock Text="{Binding HomeScanSummary}" Foreground="{DynamicResource MutedTextBrush}"
                                                   FontSize="{DynamicResource FontSize12}" TextWrapping="Wrap" />
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="Vedi aggiornamenti" Style="{StaticResource SecondaryButton}"
                                            VerticalAlignment="Center" Margin="20,0,0,0" Click="OpenUpdates_Click" />
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- AGGIORNAMENTI -->
                    <Grid x:Name="UpdatesPage" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition x:Name="UpdateFilterColumn" Width="170" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid Margin="0,0,10,0">
                                <TextBox x:Name="UpdateSearchBox" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="Cerca per nome, produttore, versione, fonte o stato"
                                         Style="{StaticResource ModernSearchBox}" />
                                <TextBlock Text="Cerca aggiornamenti" Foreground="{DynamicResource MutedTextBrush}"
                                           Margin="35,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=UpdateSearchBox}" Value="">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                            <ComboBox Grid.Column="1" SelectedValue="{Binding Filter}" SelectedValuePath="Tag" Margin="0,0,10,0">
                                <ComboBoxItem Content="Tutti" Tag="Tutti" />
                                <ComboBoxItem Content="Software" Tag="Software" />
                                <ComboBoxItem Content="Driver" Tag="Driver" />
                                <ComboBoxItem Content="Importanti" Tag="Importanti" />
                                <ComboBoxItem Content="Standard" Tag="Standard" />
                                <ComboBoxItem Content="Facoltativi" Tag="Facoltativi" />
                                <ComboBoxItem Content="Selezionati" Tag="Selezionati" />
                                <ComboBoxItem Content="Riavvio richiesto" Tag="Riavvio richiesto" />
                                <ComboBoxItem Content="Errori" Tag="Errori" />
                            </ComboBox>
                            <Button Grid.Column="2" Content="Nuova scansione" Style="{StaticResource SecondaryButton}"
                                    IsEnabled="{Binding CanScan}" Click="Scan_Click" />
                        </Grid>

                        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0" ClipToBounds="True">
                            <DataGrid x:Name="UpdatesGrid" ItemsSource="{Binding UpdatesView}"
                                      IsReadOnly="False" SelectionUnit="FullRow" Margin="0">
                                <DataGrid.Resources>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource DataGridText}" />
                                </DataGrid.Resources>
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="" Width="52">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                                    <CheckBox Style="{StaticResource ModernCheckBox}"
                                                              IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                </Grid>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTemplateColumn Header="Nome" Width="2.2*" IsReadOnly="True">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding SourceSummary}" Foreground="{DynamicResource MutedTextBrush}"
                                                               FontSize="{DynamicResource FontSize10}" Margin="0,3,0,0"
                                                               ToolTip="{Binding CompatibilityDetail}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTextColumn Header="Tipo" Binding="{Binding KindLabel}" Width="80" IsReadOnly="True"
                                                        ElementStyle="{StaticResource DataGridText}" />

                                    <DataGridTemplateColumn Header="Priorità" Width="125" IsReadOnly="True">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border x:Name="PriorityBadge" CornerRadius="8" Padding="9,5" HorizontalAlignment="Left"
                                                        VerticalAlignment="Center" Background="{DynamicResource AccentSoftBrush}" ToolTip="{Binding PriorityDescription}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock x:Name="PriorityText" Text="{Binding PriorityLabel}" Foreground="{DynamicResource AccentBrush}"
                                                                   FontSize="{DynamicResource FontSize11}" FontWeight="SemiBold" />
                                                        <TextBlock Text="  • Riavvio" Foreground="{DynamicResource WarningBrush}" FontSize="{DynamicResource FontSize10}">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock" BasedOn="{StaticResource DataGridText}">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding RequiresRestart}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Border>
                                                <DataTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding PriorityLabel}" Value="Importante">
                                                        <Setter TargetName="PriorityBadge" Property="Background" Value="{DynamicResource DangerSoftBrush}" />
                                                        <Setter TargetName="PriorityText" Property="Foreground" Value="{DynamicResource DangerBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding PriorityLabel}" Value="Important">
                                                        <Setter TargetName="PriorityBadge" Property="Background" Value="{DynamicResource DangerSoftBrush}" />
                                                        <Setter TargetName="PriorityText" Property="Foreground" Value="{DynamicResource DangerBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding PriorityLabel}" Value="Facoltativo">
                                                        <Setter TargetName="PriorityBadge" Property="Background" Value="{DynamicResource WarningSoftBrush}" />
                                                        <Setter TargetName="PriorityText" Property="Foreground" Value="{DynamicResource WarningBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding PriorityLabel}" Value="Optional">
                                                        <Setter TargetName="PriorityBadge" Property="Background" Value="{DynamicResource WarningSoftBrush}" />
                                                        <Setter TargetName="PriorityText" Property="Foreground" Value="{DynamicResource WarningBrush}" />
                                                    </DataTrigger>
                                                </DataTemplate.Triggers>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTemplateColumn Header="Versione attuale" Width="155" MinWidth="135" IsReadOnly="True">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding InstalledVersion}" Style="{StaticResource DataGridText}"
                                                           ToolTip="{Binding InstalledVersion}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="Nuova versione" Width="155" MinWidth="135" IsReadOnly="True">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding AvailableVersion}" Style="{StaticResource DataGridText}"
                                                           ToolTip="{Binding AvailableVersion}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTemplateColumn Header="Stato" Width="1.2*" IsReadOnly="True">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel VerticalAlignment="Center" ToolTip="{Binding ResultDetails}">
                                                    <TextBlock Text="{Binding Status}" FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding ResultDetails}" Foreground="{DynamicResource MutedTextBrush}"
                                                               FontSize="{DynamicResource FontSize9}" Margin="0,2,0,0" TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTemplateColumn Header="" Width="Auto">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                    <Button Content="Riprova" Padding="9,6" FontSize="{DynamicResource FontSize10}"
                                                            Click="RetryUpdate_Click"
                                                            IsEnabled="{Binding DataContext.CanScan, RelativeSource={RelativeSource AncestorType=DataGrid}}">
                                                        <Button.Style>
                                                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding CanRetry}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                    </Button>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>

                        <Grid x:Name="UpdatesFooter" Grid.Row="2" Margin="0,12,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition x:Name="UpdatesFooterSecondRow" Height="0" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <Button Content="Seleziona tutto" Style="{StaticResource SecondaryButton}" Click="SelectAll_Click" />
                                <Button Content="Deseleziona tutto" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Click="DeselectAll_Click" />
                            </StackPanel>
                            <TextBlock x:Name="VisibleUpdatesText" Grid.Column="1"
                                       Text="{Binding VisibleUpdateCount, StringFormat={}{0} risultati visibili}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{DynamicResource MutedTextBrush}" Margin="12,0" />
                            <StackPanel x:Name="UpdatesFooterRight" Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock Text="{Binding SelectedCount, StringFormat={}{0} selezionati}" VerticalAlignment="Center"
                                           Foreground="{DynamicResource MutedTextBrush}" Margin="0,0,14,0" />
                                <Button Content="Aggiorna elementi selezionati" Style="{StaticResource RoundedButton}"
                                        IsEnabled="{Binding CanUpdate}" Click="InstallSelected_Click" />
                            </StackPanel>
                        </Grid>
                    </Grid>

                    <!-- PANORAMICA HARDWARE -->
                    <ScrollViewer x:Name="SystemInfoPage" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Caratteristiche hardware" FontSize="{DynamicResource FontSize27}" FontWeight="SemiBold" />
                                        <TextBlock Text="Informazioni selezionabili e utilizzo aggiornato automaticamente."
                                                   Foreground="{DynamicResource MutedTextBrush}" Margin="0,7,0,0" />
                                        <TextBlock Text="{Binding HardwareInfo.MonitoringStatus}" Foreground="{DynamicResource SuccessBrush}"
                                                   FontSize="{DynamicResource FontSize11}" Margin="0,8,0,0" TextWrapping="Wrap" />
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="Apri Gestione attività" Style="{StaticResource RoundedButton}"
                                            VerticalAlignment="Center" Margin="20,0,0,0" Click="OpenTaskManager_Click" />
                                </Grid>
                            </Border>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="14" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                                        <StackPanel>
                                            <TextBlock Text="CPU" Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold" FontSize="{DynamicResource FontSize12}" />
                                            <TextBox Text="{Binding HardwareInfo.CpuName, Mode=OneWay}" Style="{StaticResource SelectableValue}"
                                                     FontSize="{DynamicResource FontSize18}" FontWeight="SemiBold" Margin="0,8,0,14" />
                                            <TextBlock Text="CORE E THREAD" Foreground="{DynamicResource MutedTextBrush}" FontSize="{DynamicResource FontSize10}" />
                                            <TextBox Text="{Binding HardwareInfo.CpuCores, Mode=OneWay}" Style="{StaticResource SelectableValue}"
                                                     Margin="0,5,0,14" />
                                            <Grid>
                                                <TextBlock Text="Utilizzo" Foreground="{DynamicResource MutedTextBrush}" />
                                                <TextBlock Text="{Binding HardwareInfo.CpuUsageLabel}" HorizontalAlignment="Right" FontWeight="SemiBold" />
                                            </Grid>
                                            <ProgressBar Value="{Binding HardwareInfo.CpuUsage, Mode=OneWay}" Maximum="100" Margin="0,8,0,14" />
                                            <TextBlock Text="TEMPERATURA CPU (CORE)" Foreground="{DynamicResource MutedTextBrush}" FontSize="{DynamicResource FontSize10}" />
                                            <TextBox Text="{Binding HardwareInfo.CpuTemperature, Mode=OneWay}" Style="{StaticResource SelectableValue}"
                                                     FontWeight="SemiBold" Margin="0,5,0,0" />
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                                        <StackPanel>
                                            <TextBlock Text="MEMORIA RAM" Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold" FontSize="{DynamicResource FontSize12}" />
                                            <TextBox Text="{Binding HardwareInfo.RamTotal, Mode=OneWay}" Style="{StaticResource SelectableValue}"
                                                     FontSize="{DynamicResource FontSize18}" FontWeight="SemiBold" Margin="0,8,0,12" />
                                            <Grid>
                                                <TextBlock Text="Utilizzo" Foreground="{DynamicResource MutedTextBrush}" />
                                                <TextBlock Text="{Binding HardwareInfo.RamUsageLabel}" HorizontalAlignment="Right" FontWeight="SemiBold" />
                                            </Grid>
                                            <ProgressBar Value="{Binding HardwareInfo.RamUsage, Mode=OneWay}" Maximum="100" Margin="0,8,0,10" />
                                            <TextBox Text="{Binding HardwareInfo.RamUsed, Mode=OneWay}" Style="{StaticResource SelectableValue}"
                                                     Foreground="{DynamicResource MutedTextBrush}" FontSize="{DynamicResource FontSize11}" />
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource Card}">
                                        <StackPanel>
                                            <TextBlock Text="SISTEMA OPERATIVO" Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold" FontSize="{DynamicResource FontSize12}" />
                                            <TextBox Text="{Binding HardwareInfo.OperatingSystem, Mode=OneWay}" Style="{StaticResource SelectableValue}"
                                                     FontSize="{DynamicResource FontSize15}" FontWeight="SemiBold" Margin="0,8,0,12" />
                                            <TextBlock Text="COMPUTER" Foreground="{DynamicResource MutedTextBrush}" FontSize="{DynamicResource FontSize10}" />
                                            <TextBox Text="{Binding HardwareInfo.ComputerModel, Mode=OneWay}" Style="{StaticResource SelectableValue}"
                                                     Margin="0,5,0,0" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                                        <StackPanel>
                                            <TextBlock Text="SCHEDA VIDEO" Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold" FontSize="{DynamicResource FontSize12}" />
                                            <TextBox Text="{Binding HardwareInfo.GpuName, Mode=OneWay}" Style="{StaticResource SelectableValue}"
                                                     FontSize="{DynamicResource FontSize18}" FontWeight="SemiBold" Margin="0,8,0,14" />
                                            <TextBlock Text="VRAM" Foreground="{DynamicResource MutedTextBrush}" FontSize="{DynamicResource FontSize10}" />
                                            <TextBox Text="{Binding HardwareInfo.VramTotal, Mode=OneWay}" Style="{StaticResource SelectableValue}"
                                                     Margin="0,5,0,6" />
                                            <TextBlock Text="VRAM IN USO" Foreground="{DynamicResource MutedTextBrush}" FontSize="{DynamicResource FontSize10}" />
                                            <TextBox Text="{Binding HardwareInfo.VramUsed, Mode=OneWay}"
                                                     Style="{StaticResource SelectableValue}" Foreground="{DynamicResource MutedTextBrush}"
                                                     FontSize="{DynamicResource FontSize11}" Margin="0,4,0,14" />
                                            <Grid>
                                                <TextBlock Text="Utilizzo" Foreground="{DynamicResource MutedTextBrush}" />
                                                <TextBlock Text="{Binding HardwareInfo.GpuUsageLabel}" HorizontalAlignment="Right" FontWeight="SemiBold" />
                                            </Grid>
                                            <ProgressBar Value="{Binding HardwareInfo.GpuUsage, Mode=OneWay}" Maximum="100" Margin="0,8,0,14" />
                                            <TextBlock Text="TEMPERATURA GPU" Foreground="{DynamicResource MutedTextBrush}" FontSize="{DynamicResource FontSize10}" />
                                            <TextBox Text="{Binding HardwareInfo.GpuTemperature, Mode=OneWay}" Style="{StaticResource SelectableValue}"
                                                     FontWeight="SemiBold" Margin="0,5,0,0" />
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                                        <StackPanel>
                                            <TextBlock Text="SCHERMO" Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold" FontSize="{DynamicResource FontSize12}" />
                                            <TextBlock Text="RISOLUZIONE" Foreground="{DynamicResource MutedTextBrush}" FontSize="{DynamicResource FontSize10}" Margin="0,12,0,0" />
                                            <TextBox Text="{Binding HardwareInfo.Resolution, Mode=OneWay}" Style="{StaticResource SelectableValue}"
                                                     FontSize="{DynamicResource FontSize18}" FontWeight="SemiBold" Margin="0,5,0,12" />
                                            <TextBlock Text="FREQUENZA" Foreground="{DynamicResource MutedTextBrush}" FontSize="{DynamicResource FontSize10}" />
                                            <TextBox Text="{Binding HardwareInfo.RefreshRate, Mode=OneWay}" Style="{StaticResource SelectableValue}"
                                                     FontSize="{DynamicResource FontSize15}" FontWeight="SemiBold" Margin="0,5,0,0" />
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource Card}">
                                        <StackPanel>
                                            <TextBlock Text="Sensori temperatura" FontWeight="SemiBold" />
                                            <TextBlock Text="Le temperature compaiono solo se firmware o driver espongono i sensori a Windows. Nessun driver di monitoraggio viene installato."
                                                       Foreground="{DynamicResource MutedTextBrush}" FontSize="{DynamicResource FontSize11}" TextWrapping="Wrap" Margin="0,7,0,0" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <Border Style="{StaticResource Card}" Margin="0,14,0,0">
                                <Grid>
                                    <StackPanel>
                                        <TextBlock Text="Riepilogo completo" FontWeight="SemiBold" FontSize="{DynamicResource FontSize16}" />
                                        <TextBlock Text="Copia CPU, GPU, temperature, utilizzo, RAM, schermo e versione di Windows in un formato leggibile."
                                                   Foreground="{DynamicResource MutedTextBrush}" FontSize="{DynamicResource FontSize11}" Margin="0,5,220,0" TextWrapping="Wrap" />
                                    </StackPanel>
                                    <Button Content="Copia informazioni hardware" Style="{StaticResource RoundedButton}"
                                            HorizontalAlignment="Right" VerticalAlignment="Center" Click="CopyHardwareInfo_Click" />
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- DRIVER E CHIPSET -->
                    <ScrollViewer x:Name="HardwarePage" Visibility="Collapsed"
                                  VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>

                        <Border x:Name="DriverHeaderCard" Style="{StaticResource Card}" Padding="18" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Driver e chipset" FontSize="{DynamicResource FontSize25}" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding CpuName}" FontSize="{DynamicResource FontSize15}" Margin="0,8,0,0" />
                                    <TextBlock x:Name="DriverMachineName" Text="{Binding ComputerName}" Foreground="{DynamicResource MutedTextBrush}"
                                               FontSize="{DynamicResource FontSize12}" Margin="0,4,0,0" />
                                    <TextBlock Text="{Binding HardwareCheckStatus}" Foreground="{DynamicResource SuccessBrush}"
                                               FontSize="{DynamicResource FontSize12}" FontWeight="SemiBold" Margin="0,7,0,0"
                                               TextWrapping="Wrap" />
                                    <TextBlock x:Name="DriverSourceDescription" Text="Update Center usa Windows/Microsoft Update e metadati verificati con collegamenti diretti ai produttori. Se una fonte ufficiale non è interrogabile in modo sicuro, viene indicato un controllo manuale senza installare altre app."
                                               Foreground="{DynamicResource MutedTextBrush}" FontSize="{DynamicResource FontSize10}"
                                               Margin="0,5,30,0" TextWrapping="Wrap" />
                                </StackPanel>
                                <StackPanel x:Name="DriverSummaryPanel" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <StackPanel HorizontalAlignment="Right">
                                        <TextBlock Text="AGGIORNAMENTI VERIFICATI" Foreground="{DynamicResource MutedTextBrush}"
                                                   FontSize="{DynamicResource FontSize10}" FontWeight="SemiBold" HorizontalAlignment="Right" />
                                        <TextBlock Text="{Binding DriverUpdateCount}" Foreground="{DynamicResource DangerBrush}"
                                                   FontSize="{DynamicResource FontSize30}" FontWeight="SemiBold" HorizontalAlignment="Right" />
                                    </StackPanel>
                                    <Border Width="1" Background="{DynamicResource BorderBrush}" Margin="20,0" />
                                    <StackPanel HorizontalAlignment="Right">
                                        <TextBlock Text="CONTROLLI PRODUTTORE" Foreground="{DynamicResource MutedTextBrush}"
                                                   FontSize="{DynamicResource FontSize10}" FontWeight="SemiBold" HorizontalAlignment="Right" />
                                        <TextBlock Text="{Binding VendorCheckCount}" Foreground="{DynamicResource AccentBrush}"
                                                   FontSize="{DynamicResource FontSize30}" FontWeight="SemiBold" HorizontalAlignment="Right" />
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0" Margin="0,0,0,10" ClipToBounds="True">
                            <Expander x:Name="DriverVendorExpander" IsExpanded="True" HorizontalContentAlignment="Stretch">
                                <Expander.Header>
                                    <StackPanel Orientation="Horizontal" MinHeight="42" Margin="12,0,14,0">
                                        <TextBlock Text="Controlli e supporto produttore" FontWeight="SemiBold"
                                                   FontSize="{DynamicResource FontSize13}" VerticalAlignment="Center" />
                                        <TextBlock Margin="12,0,0,0" Foreground="{DynamicResource MutedTextBrush}" VerticalAlignment="Center">
                                            <Run Text="{Binding VendorCheckCount, Mode=OneWay}" /><Run Text=" disponibili" />
                                        </TextBlock>
                                    </StackPanel>
                                </Expander.Header>
                                <ScrollViewer Height="142" Margin="12,0,12,12"
                                              HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                                              CanContentScroll="True">
                                    <ItemsControl ItemsSource="{Binding VendorTools}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Width="290" Height="134" Background="{DynamicResource SurfaceAltBrush}"
                                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                                        CornerRadius="13" Margin="0,0,9,0" Padding="13">
                                                    <Grid ToolTip="{Binding CompatibilityLabel}">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="*" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>
                                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                                   FontSize="{DynamicResource FontSize13}" TextTrimming="CharacterEllipsis" />
                                                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,5,0,4">
                                                            <Border Background="{DynamicResource AccentSoftBrush}" CornerRadius="7" Padding="6,2" Margin="0,0,6,0">
                                                                <TextBlock Text="{Binding ConfidenceLabel}" Foreground="{DynamicResource AccentBrush}"
                                                                           FontSize="{DynamicResource FontSize9}" FontWeight="SemiBold" />
                                                            </Border>
                                                            <TextBlock Text="{Binding SourceLabel}" Foreground="{DynamicResource MutedTextBrush}"
                                                                       FontSize="{DynamicResource FontSize9}" VerticalAlignment="Center"
                                                                       TextTrimming="CharacterEllipsis" />
                                                        </StackPanel>
                                                        <TextBlock Grid.Row="2" Text="{Binding Description}" Foreground="{DynamicResource MutedTextBrush}"
                                                                   FontSize="{DynamicResource FontSize9}" TextWrapping="Wrap"
                                                                   MaxHeight="30" TextTrimming="CharacterEllipsis" />
                                                        <Button Grid.Row="3" Content="{Binding ActionLabel}" Tag="{Binding Url}"
                                                                Style="{StaticResource SecondaryButton}" HorizontalAlignment="Left"
                                                                Padding="10,5" FontSize="{DynamicResource FontSize10}" Click="OpenVendorSupport_Click" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Expander>
                        </Border>

                        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0" ClipToBounds="True" Margin="0,0,0,2">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Grid Background="{DynamicResource SurfaceAltBrush}" MinHeight="56">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center" Margin="16,8">
                                        <TextBlock Text="Inventario driver installati" FontWeight="SemiBold" FontSize="{DynamicResource FontSize14}" />
                                        <TextBlock Foreground="{DynamicResource MutedTextBrush}" FontSize="{DynamicResource FontSize10}" Margin="0,3,0,0">
                                            <Run Text="{Binding DriverCount, Mode=OneWay}" /><Run Text=" dispositivi · " />
                                            <Run Text="{Binding ChipsetCount, Mode=OneWay}" /><Run Text=" CPU/chipset" />
                                        </TextBlock>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{Binding VisibleDriverCount, StringFormat={}{0} visibili}"
                                               Foreground="{DynamicResource MutedTextBrush}" VerticalAlignment="Center" Margin="16,8" />
                                </Grid>

                                <Grid Grid.Row="1" Margin="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition x:Name="DriverFilterColumn" Width="190" />
                                    </Grid.ColumnDefinitions>
                                    <Grid Margin="0,0,10,0">
                                        <TextBox x:Name="DriverInventorySearchBox"
                                                 Text="{Binding DriverSearchText, UpdateSourceTrigger=PropertyChanged}"
                                                 ToolTip="Cerca per dispositivo, categoria, produttore, versione o ID hardware"
                                                 Style="{StaticResource ModernSearchBox}" />
                                        <TextBlock Text="Cerca nei dispositivi" Foreground="{DynamicResource MutedTextBrush}"
                                                   Margin="35,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Text, ElementName=DriverInventorySearchBox}" Value="">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                    <ComboBox Grid.Column="1" SelectedValue="{Binding DriverInventoryFilter}"
                                              SelectedValuePath="Tag">
                                        <ComboBoxItem Content="Tutti" Tag="Tutti" />
                                        <ComboBoxItem Content="Con aggiornamenti" Tag="Con aggiornamenti" />
                                        <ComboBoxItem Content="CPU e chipset" Tag="CPU e chipset" />
                                        <ComboBoxItem Content="Grafica" Tag="Grafica" />
                                        <ComboBoxItem Content="Audio" Tag="Audio" />
                                        <ComboBoxItem Content="Rete" Tag="Rete" />
                                    </ComboBox>
                                </Grid>

                                <DataGrid x:Name="DriverInventoryGrid" Grid.Row="2"
                                          ItemsSource="{Binding DriverInventoryView, Mode=OneWay}" IsReadOnly="True"
                                          SelectionUnit="FullRow" VerticalContentAlignment="Center"
                                          ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                          PreviewMouseWheel="DriverInventoryGrid_PreviewMouseWheel">
                                    <DataGrid.Resources>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource DataGridText}" />
                                    </DataGrid.Resources>
                                    <DataGrid.Columns>
                                        <DataGridTemplateColumn Header="Dispositivo" Width="2.4*">
                                            <DataGridTemplateColumn.HeaderStyle>
                                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                                    <Setter Property="Padding" Value="16,10,10,10" />
                                                </Style>
                                            </DataGridTemplateColumn.HeaderStyle>
                                            <DataGridTemplateColumn.CellStyle>
                                                <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                                                    <Setter Property="Padding" Value="16,6,10,6" />
                                                </Style>
                                            </DataGridTemplateColumn.CellStyle>
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel VerticalAlignment="Center" Margin="16,0,0,0">
                                                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" ToolTip="{Binding DeviceName}" />
                                                        <TextBlock Foreground="{DynamicResource MutedTextBrush}"
                                                                   FontSize="{DynamicResource FontSize10}" Margin="0,3,0,0">
                                                            <Run Text="{Binding CategoryLabel, Mode=OneWay}" /><Run Text=" · " /><Run Text="{Binding ProviderLabel, Mode=OneWay}" />
                                                        </TextBlock>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Header="Versione installata" Width="1.15*" MinWidth="155">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding InstalledVersion}" FontWeight="SemiBold"
                                                                   ToolTip="{Binding InstalledVersion}" />
                                                        <TextBlock Text="{Binding DriverDateLabel, StringFormat=Data: {0}}"
                                                                   Foreground="{DynamicResource MutedTextBrush}"
                                                                   FontSize="{DynamicResource FontSize10}" Margin="0,3,0,0" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Header="Stato fonti ufficiali" Width="1.55*" MinWidth="230">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel VerticalAlignment="Center">
                                                        <Border x:Name="DriverStatusBadge" Background="{DynamicResource AccentSoftBrush}"
                                                                CornerRadius="8" Padding="9,4" HorizontalAlignment="Left">
                                                            <TextBlock x:Name="DriverStatusText" Text="{Binding Status}"
                                                                       Foreground="{DynamicResource AccentBrush}"
                                                                       FontSize="{DynamicResource FontSize11}" FontWeight="SemiBold" />
                                                        </Border>
                                                        <TextBlock Text="{Binding StatusDetail}" Foreground="{DynamicResource MutedTextBrush}"
                                                                   FontSize="{DynamicResource FontSize9}" Margin="0,3,0,0"
                                                                   TextTrimming="CharacterEllipsis" ToolTip="{Binding StatusDetail}" />
                                                    </StackPanel>
                                                    <DataTemplate.Triggers>
                                                        <DataTrigger Binding="{Binding HasUpdate}" Value="True">
                                                            <Setter TargetName="DriverStatusBadge" Property="Background" Value="{DynamicResource DangerSoftBrush}" />
                                                            <Setter TargetName="DriverStatusText" Property="Foreground" Value="{DynamicResource DangerBrush}" />
                                                        </DataTrigger>
                                                    </DataTemplate.Triggers>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Header="" Width="112">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Content="Vedi update"
                                                            Padding="11,6" FontSize="{DynamicResource FontSize11}"
                                                            Click="OpenUpdates_Click">
                                                        <Button.Style>
                                                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding HasUpdate}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                    </Button>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- CRONOLOGIA -->
                    <Grid x:Name="HistoryPage" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Border Margin="0,0,0,12" Padding="14,9" MinHeight="52"
                                Background="{DynamicResource InputBrush}" BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1" CornerRadius="11">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border Width="32" Height="32" CornerRadius="9" VerticalAlignment="Center"
                                        Background="{DynamicResource AccentSoftBrush}">
                                    <TextBlock Text="◷" Foreground="{DynamicResource AccentBrush}" FontSize="{DynamicResource FontSize16}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <StackPanel Grid.Column="1" Margin="11,0,12,0" VerticalAlignment="Center">
                                    <TextBlock Text="Registro aggiornamenti" FontWeight="SemiBold" FontSize="{DynamicResource FontSize14}" />
                                    <TextBlock Text="Esiti, versioni e spiegazioni delle operazioni eseguite"
                                               Foreground="{DynamicResource MutedTextBrush}" FontSize="{DynamicResource FontSize10}"
                                               Margin="0,2,0,0" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                                <Border x:Name="HistoryHintBadge" Grid.Column="2" Padding="10,6" CornerRadius="9"
                                        Background="{DynamicResource AccentSoftBrush}" VerticalAlignment="Center">
                                    <TextBlock Text="Dettagli completi dopo 1 secondo" Foreground="{DynamicResource AccentBrush}"
                                               FontSize="{DynamicResource FontSize10}" FontWeight="SemiBold" />
                                </Border>
                            </Grid>
                        </Border>
                        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0" ClipToBounds="True">
                            <DataGrid x:Name="HistoryGrid" ItemsSource="{Binding History}" IsReadOnly="True"
                                      SelectionUnit="FullRow" VerticalContentAlignment="Center" Margin="0">
                                <DataGrid.Resources>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource DataGridText}" />
                                </DataGrid.Resources>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Data" Binding="{Binding DisplayDate}" Width="135" ElementStyle="{StaticResource DataGridText}" />
                                    <DataGridTemplateColumn Header="Nome" Width="2*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="{Binding Kind}" Foreground="{DynamicResource MutedTextBrush}"
                                                               FontSize="{DynamicResource FontSize10}" Margin="0,3,0,0" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Da" Binding="{Binding FromVersion}" Width="120" ElementStyle="{StaticResource DataGridText}" />
                                    <DataGridTextColumn Header="A" Binding="{Binding ToVersion}" Width="120" ElementStyle="{StaticResource DataGridText}" />
                                    <DataGridTemplateColumn Header="Esito" Width="105">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border x:Name="HistoryResultBadge" Padding="9,5" CornerRadius="8"
                                                        HorizontalAlignment="Left" VerticalAlignment="Center"
                                                        Background="{DynamicResource AccentSoftBrush}">
                                                    <TextBlock x:Name="HistoryResultText" Text="{Binding Result}"
                                                               Foreground="{DynamicResource SuccessBrush}"
                                                               FontSize="{DynamicResource FontSize11}" FontWeight="SemiBold" />
                                                </Border>
                                                <DataTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding Result}" Value="Fallito">
                                                        <Setter TargetName="HistoryResultBadge" Property="Background" Value="{DynamicResource DangerSoftBrush}" />
                                                        <Setter TargetName="HistoryResultText" Property="Foreground" Value="{DynamicResource DangerBrush}" />
                                                    </DataTrigger>
                                                </DataTemplate.Triggers>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="Dettagli" Width="2.2*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border Background="Transparent" Cursor="Hand"
                                                        MouseEnter="HistoryDetail_MouseEnter" MouseLeave="HistoryDetail_MouseLeave"
                                                        PreviewMouseDown="HistoryDetail_PreviewMouseDown"
                                                        PreviewMouseUp="HistoryDetail_PreviewMouseUp">
                                                    <TextBlock Text="{Binding Details}" Style="{StaticResource DataGridText}" />
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>

                        <Grid Grid.Row="2" Margin="0,12,0,0">
                            <TextBlock Text="{Binding History.Count, StringFormat={}{0} operazioni registrate}"
                                       VerticalAlignment="Center" Foreground="{DynamicResource MutedTextBrush}" />
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="Apri log" Style="{StaticResource SecondaryButton}" Click="OpenLogs_Click" />
                                <Button Content="Cancella cronologia" Style="{StaticResource SecondaryButton}"
                                        Margin="8,0,0,0" Click="ClearHistory_Click" />
                            </StackPanel>
                        </Grid>

                        <Popup x:Name="HistoryDetailPopup" Placement="Custom" AllowsTransparency="True"
                               PopupAnimation="Fade" StaysOpen="False" Closed="HistoryDetailPopup_Closed">
                            <Border Width="500" MaxHeight="360" Padding="18" Margin="8"
                                    Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="16">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="22" ShadowDepth="5" Opacity="0.20" />
                                </Border.Effect>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid>
                                        <TextBlock Text="Dettaglio attività" Foreground="{DynamicResource AccentBrush}"
                                                   FontWeight="SemiBold" FontSize="{DynamicResource FontSize12}" />
                                        <Button Content="×" Style="{StaticResource WindowButton}" Width="30" Height="28"
                                                HorizontalAlignment="Right" Click="CloseHistoryDetail_Click" />
                                    </Grid>
                                    <TextBlock x:Name="HistoryDetailTitle" Grid.Row="1" Margin="0,8,0,10"
                                               FontWeight="SemiBold" FontSize="{DynamicResource FontSize16}"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBox x:Name="HistoryDetailText" Grid.Row="2" MinHeight="92" MaxHeight="205"
                                             IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto" VerticalContentAlignment="Top"
                                             SelectionBrush="{DynamicResource SelectionBrush}" />
                                    <Grid Grid.Row="3" Margin="0,12,0,0">
                                        <TextBlock x:Name="HistoryDetailStatus" Foreground="{DynamicResource SuccessBrush}"
                                                   FontSize="{DynamicResource FontSize11}" VerticalAlignment="Center" />
                                        <Button Content="Copia dettaglio" Style="{StaticResource SecondaryButton}"
                                                HorizontalAlignment="Right" Padding="13,7" Click="CopyHistoryDetail_Click" />
                                    </Grid>
                                </Grid>
                            </Border>
                        </Popup>
                    </Grid>

                    <!-- IMPOSTAZIONI -->
                    <ScrollViewer x:Name="SettingsPage" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="Impostazioni" FontSize="{DynamicResource FontSize24}" FontWeight="SemiBold" />
                            <TextBlock Text="Controlla il comportamento di scansione e installazione" Foreground="{DynamicResource MutedTextBrush}" Margin="0,5,0,20" />
                            <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                                <StackPanel>
                                    <TextBlock Text="Sicurezza" FontSize="{DynamicResource FontSize17}" FontWeight="SemiBold" Margin="0,0,0,16" />
                                    <CheckBox IsChecked="{Binding Settings.CreateRestorePoint}" Content="Crea un punto di ripristino per driver e aggiornamenti importanti" />
                                    <TextBlock Text="Viene richiesto un solo punto per l'intero gruppo. I soli aggiornamenti software non ne creano uno; lo spazio è gestito da Protezione sistema di Windows."
                                               Foreground="{DynamicResource MutedTextBrush}" FontSize="{DynamicResource FontSize11}" Margin="24,5,0,0" TextWrapping="Wrap" />
                                    <Button Content="Gestisci spazio in Windows" Style="{StaticResource SecondaryButton}"
                                            HorizontalAlignment="Left" Margin="24,12,0,0" Padding="13,7"
                                            Click="OpenSystemProtection_Click" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                                <StackPanel>
                                    <TextBlock Text="Software" FontSize="{DynamicResource FontSize17}" FontWeight="SemiBold" Margin="0,0,0,16" />
                                    <CheckBox IsChecked="{Binding Settings.SilentSoftwareInstall}" Content="Richiedi a WinGet installazioni silenziose quando supportate" />
                                    <CheckBox IsChecked="{Binding Settings.IncludeUnknownVersions}" Margin="0,14,0,0"
                                              Content="Includi programmi la cui versione installata non è riconoscibile" />
                                    <TextBlock Text="Le versioni preview non vengono richieste: WinGet usa il canale stabile previsto dal pacchetto."
                                               Foreground="{DynamicResource MutedTextBrush}" FontSize="{DynamicResource FontSize11}" Margin="24,5,0,0" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                                <StackPanel>
                                    <TextBlock Text="Aggiornamenti di Update Center" FontSize="{DynamicResource FontSize17}"
                                               FontWeight="SemiBold" Margin="0,0,0,16" />
                                    <CheckBox IsChecked="{Binding Settings.CheckAppUpdatesAutomatically}"
                                              Content="Controlla automaticamente gli aggiornamenti" />
                                    <TextBlock Text="Il controllo usa esclusivamente le Release stabili ufficiali su GitHub e viene eseguito al massimo una volta ogni 24 ore."
                                               Foreground="{DynamicResource MutedTextBrush}" FontSize="{DynamicResource FontSize11}"
                                               Margin="24,5,0,0" TextWrapping="Wrap" />
                                    <Grid Margin="0,16,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="ULTIMO CONTROLLO" Foreground="{DynamicResource MutedTextBrush}"
                                                       FontSize="{DynamicResource FontSize10}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding LastAppUpdateCheckLabel}" FontWeight="SemiBold" Margin="0,4,0,0" />
                                            <TextBlock Text="{Binding AppUpdateStatus}" Foreground="{DynamicResource MutedTextBrush}"
                                                       FontSize="{DynamicResource FontSize11}" Margin="0,3,18,0" TextWrapping="Wrap" />
                                        </StackPanel>
                                        <Button Grid.Column="1" Content="Controlla ora" Style="{StaticResource SecondaryButton}"
                                                IsEnabled="{Binding CanCheckAppUpdates}" VerticalAlignment="Center"
                                                Click="CheckForAppUpdates_Click" />
                                    </Grid>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                                <StackPanel>
                                    <TextBlock Text="Aspetto" FontSize="{DynamicResource FontSize17}" FontWeight="SemiBold" />
                                    <TextBlock Text="Scegli il tema oppure segui automaticamente quello delle app di Windows."
                                               Foreground="{DynamicResource MutedTextBrush}" FontSize="{DynamicResource FontSize11}" Margin="0,5,0,14" />
                                    <StackPanel Orientation="Horizontal">
                                        <RadioButton x:Name="SystemThemeChoice" Content="Sistema" Tag="Sistema" GroupName="ThemeMode"
                                                     Style="{StaticResource ThemeChoice}" Click="ThemeChoice_Click" />
                                        <RadioButton x:Name="LightThemeChoice" Content="Chiaro" Tag="Chiaro" GroupName="ThemeMode"
                                                     Style="{StaticResource ThemeChoice}" Click="ThemeChoice_Click" />
                                        <RadioButton x:Name="DarkThemeChoice" Content="Scuro" Tag="Scuro" GroupName="ThemeMode"
                                                     Style="{StaticResource ThemeChoice}" Click="ThemeChoice_Click" />
                                    </StackPanel>
                                    <TextBlock Text="Dimensione del testo" FontSize="{DynamicResource FontSize15}" FontWeight="SemiBold" Margin="0,18,0,0" />
                                    <TextBlock Text="Piccola corrisponde alla precedente Media; Media e Grande aumentano progressivamente tutti i testi."
                                               Foreground="{DynamicResource MutedTextBrush}" FontSize="{DynamicResource FontSize11}" Margin="0,5,0,12" />
                                    <StackPanel Orientation="Horizontal">
                                        <RadioButton x:Name="SmallFontChoice" Content="Piccola" Tag="Piccola" GroupName="FontSizeMode"
                                                     Style="{StaticResource ThemeChoice}" Click="FontSizeChoice_Click" />
                                        <RadioButton x:Name="MediumFontChoice" Content="Media" Tag="Media" GroupName="FontSizeMode"
                                                     Style="{StaticResource ThemeChoice}" Click="FontSizeChoice_Click" />
                                        <RadioButton x:Name="LargeFontChoice" Content="Grande" Tag="Grande" GroupName="FontSizeMode"
                                                     Style="{StaticResource ThemeChoice}" Click="FontSizeChoice_Click" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                                <StackPanel>
                                    <TextBlock Text="Avvio e scansioni automatiche" FontSize="{DynamicResource FontSize17}" FontWeight="SemiBold" Margin="0,0,0,16" />
                                    <CheckBox IsChecked="{Binding Settings.ScanAtStartup}" Content="Avvia automaticamente la scansione all'apertura" />
                                    <TextBlock Text="Frequenza scansione" FontWeight="SemiBold" Margin="0,17,0,8" />
                                    <ComboBox SelectedValue="{Binding Settings.AutomaticScanInterval, Mode=TwoWay}"
                                              SelectedValuePath="Tag" Width="220" HorizontalAlignment="Left">
                                        <ComboBoxItem Content="Disattivata" Tag="Off" />
                                        <ComboBoxItem Content="Ogni giorno" Tag="Daily" />
                                        <ComboBoxItem Content="Ogni settimana" Tag="Weekly" />
                                    </ComboBox>
                                    <TextBlock Text="La scansione periodica viene eseguita mentre Update Center è aperto oppure al successivo avvio, se è scaduta. L'installazione richiede sempre la tua conferma."
                                               Foreground="{DynamicResource MutedTextBrush}" FontSize="{DynamicResource FontSize11}"
                                               Margin="0,7,0,0" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                                <StackPanel>
                                    <TextBlock Text="Notifiche" FontSize="{DynamicResource FontSize17}" FontWeight="SemiBold" Margin="0,0,0,16" />
                                    <CheckBox IsChecked="{Binding Settings.NotifyWhenUpdatesAreAvailable}"
                                              Content="Avvisami quando vengono trovati aggiornamenti" />
                                    <TextBlock Text="Le notifiche sono locali e non richiedono account o servizi di telemetria."
                                               Foreground="{DynamicResource MutedTextBrush}" FontSize="{DynamicResource FontSize11}"
                                               Margin="24,5,0,0" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                                <StackPanel>
                                    <TextBlock Text="Lingua" FontSize="{DynamicResource FontSize17}" FontWeight="SemiBold" Margin="0,0,0,14" />
                                    <StackPanel Orientation="Horizontal">
                                        <RadioButton x:Name="ItalianLanguageChoice" Content="Italiano" Tag="it" GroupName="LanguageMode"
                                                     Style="{StaticResource ThemeChoice}" Click="LanguageChoice_Click" />
                                        <RadioButton x:Name="EnglishLanguageChoice" Content="Inglese" Tag="en" GroupName="LanguageMode"
                                                     Style="{StaticResource ThemeChoice}" Click="LanguageChoice_Click" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="Informazioni sul progetto" FontSize="{DynamicResource FontSize17}" FontWeight="SemiBold" />
                                    <TextBlock Text="Update Center per Windows 10 e Windows 11"
                                               Foreground="{DynamicResource MutedTextBrush}" Margin="0,5,0,16" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Ideato e sviluppato da" Foreground="{DynamicResource MutedTextBrush}" />
                                            <TextBlock Text="Illidan0S" FontWeight="SemiBold" Margin="0,5,12,0" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Versione installata" Foreground="{DynamicResource MutedTextBrush}" />
                                            <TextBlock x:Name="AboutVersionText" FontWeight="SemiBold" Margin="0,5,12,0" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Licenza" Foreground="{DynamicResource MutedTextBrush}" />
                                            <TextBlock Text="MIT" FontWeight="SemiBold" Margin="0,5,0,0" />
                                        </StackPanel>
                                    </Grid>
                                    <TextBlock Text="Update Center non raccoglie dati personali e non include telemetria."
                                               Foreground="{DynamicResource MutedTextBrush}" Margin="0,16,0,0" TextWrapping="Wrap" />
                                    <TextBlock Text="Scansioni, impostazioni, cronologia e log restano memorizzati localmente sul computer."
                                               Foreground="{DynamicResource MutedTextBrush}" Margin="0,5,0,0" TextWrapping="Wrap" />
                                    <Button Content="Apri GitHub" Style="{StaticResource SecondaryButton}" HorizontalAlignment="Left"
                                            Margin="0,14,0,0" Tag="https://github.com/Illidan0S/UpdateCenter" Click="OpenVendorSupport_Click" />
                                </StackPanel>
                            </Border>
                            <Button Content="Salva impostazioni" Style="{StaticResource RoundedButton}" HorizontalAlignment="Left"
                                    Margin="0,18,0,0" Click="SaveSettings_Click" />
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
